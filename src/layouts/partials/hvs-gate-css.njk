<style id="hvs-gate-styles">
#site-auth-checking,
#site-auth-wall { display: none; }
html.hvs-public #site-main-content { display: block !important; }
html.hvs-public #site-auth-checking,
html.hvs-public #site-auth-wall { display: none !important; }
html.hvs-needs-auth:not(.hvs-auth-ok):not(.hvs-auth-fail) #site-main-content { display: none !important; }
html.hvs-needs-auth:not(.hvs-auth-ok):not(.hvs-auth-fail) #site-auth-checking { display: block; }
html.hvs-needs-auth.hvs-auth-ok #site-main-content { display: block; }
html.hvs-needs-auth.hvs-auth-ok #site-auth-checking,
html.hvs-needs-auth.hvs-auth-ok #site-auth-wall { display: none; }
html.hvs-needs-auth.hvs-auth-fail #site-main-content,
html.hvs-needs-auth.hvs-auth-fail #site-auth-checking { display: none !important; }
html.hvs-needs-auth.hvs-auth-fail #site-auth-wall { display: block; }
</style>
