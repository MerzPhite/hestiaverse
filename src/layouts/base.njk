<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} | {% endif %}HESTIA VERSE</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            bg: '#0f1419',
            surface: '#1a2332',
            'surface-hover': '#243044',
            muted: '#8b98a5',
            accent: '#1d9bf0',
            warning: '#ff6b35',
            border: '#2f3542',
          },
          fontFamily: {
            sans: ['DM Sans', 'system-ui', 'sans-serif'],
            mono: ['Fragment Mono', 'monospace'],
          },
        },
      },
    };
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,600;0,9..40,700;1,9..40,400&family=Fragment+Mono:ital@0;1&display=swap" rel="stylesheet">
  {% include "partials/hvs-gate-css.njk" %}
  {% if env.siteUrl %}
  {% set supabaseConfig = { url: env.supabaseUrl, anonKey: env.supabaseAnonKey, siteUrl: env.siteUrl ~ "/" } %}
  {% else %}
  {% set supabaseConfig = { url: env.supabaseUrl, anonKey: env.supabaseAnonKey } %}
  {% endif %}
  <script type="application/json" id="supabase-config">{{ supabaseConfig | json | safe }}</script>
</head>
<body class="font-sans bg-bg text-[#e7e9ea] leading-relaxed min-h-screen scroll-smooth">
  {% include "partials/hvs-gate-body-open.njk" %}
  <header class="bg-gradient-to-b from-surface to-bg border-b border-border py-8 px-6 pb-12 text-center">
    <div class="mb-4">
      <nav class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 sm:gap-x-6" aria-label="Main">
        {% for item in site.nav %}
        {% set isConnection = item.url == "/connection/" or item.url == "/connection-2/" %}
        {% if env.showConnectionNav or not isConnection %}
        <a href="{{ item.url }}" class="text-[1rem] font-semibold tracking-tight no-underline hover:text-accent focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-bg rounded {% if page.url == item.url %}text-accent{% else %}text-[#e7e9ea]{% endif %}">{{ item.label }}</a>
        {% endif %}
        {% endfor %}

        <div class="relative" id="settings-menu" hidden>
          <button
            id="settings-menu-button"
            type="button"
            class="inline-flex items-center gap-2 py-2 px-3 rounded-lg bg-border text-[#e7e9ea] text-sm font-semibold hover:bg-surface-hover focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-bg"
            aria-haspopup="menu"
            aria-expanded="false"
          >
            Settings
            <span class="text-muted" aria-hidden="true">▾</span>
          </button>

          <div
            id="settings-menu-panel"
            class="absolute left-1/2 -translate-x-1/2 sm:left-auto sm:right-0 sm:translate-x-0 mt-2 w-[min(22rem,90vw)] rounded-xl border border-border bg-surface shadow-xl p-4 text-left z-30"
            role="menu"
            aria-label="Account settings"
            hidden
          >
            <div class="text-xs text-muted mb-3">
              Signed in as <span id="settings-user-email" class="text-[#e7e9ea] font-semibold">…</span>
            </div>

            <div class="rounded-lg bg-bg border border-border p-3 mb-3">
              <div class="text-xs text-muted">Subscription</div>
              <div class="mt-1 text-sm font-semibold" id="settings-subscription-status">Loading…</div>
              <div class="mt-1 text-xs text-muted whitespace-pre-line" id="settings-subscription-detail"></div>
            </div>

            <div class="flex items-center justify-between gap-3">
              <a href="/subscribe/" class="text-sm text-accent no-underline hover:underline" role="menuitem">Manage plans</a>
              <button
                id="settings-cancel-subscription"
                type="button"
                class="py-2 px-3 rounded-lg bg-warning text-bg text-sm font-semibold hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-warning focus:ring-offset-2 focus:ring-offset-surface disabled:opacity-50"
                role="menuitem"
                disabled
              >
                Cancel
              </button>
            </div>

            <p id="settings-subscription-error" class="text-xs text-warning mt-3" hidden></p>
          </div>
        </div>
      </nav>
    </div>
    <h1 class="text-2xl sm:text-[clamp(1.5rem,4vw,2rem)] font-bold mb-2 tracking-tight">
      HESTIA VERSE
    </h1>
    <p class="text-muted text-[0.95rem] max-w-[42ch] mx-auto tagline">
      Helping parents stay ahead of the online world their children live in.
    </p>
  </header>

  <main class="max-w-4xl mx-auto py-8 px-6 pb-16">
    {% include "partials/hvs-gate-main-shell-start.njk" %}
    {{ content | safe }}
    {% include "partials/hvs-gate-main-shell-end.njk" %}
  </main>

  <footer class="text-center py-8 px-6 border-t border-border text-muted text-[0.85rem]">
    <p>For crisis or reporting: <a href="https://www.missingkids.org/gethelpnow/cybertipline" target="_blank" rel="noopener" class="text-accent no-underline hover:underline">NCMEC CyberTipline</a>. This page is informational only and not affiliated with any organization.</p>
  </footer>

  <script type="module" src="/js/main.js"></script>
  <script type="module" src="/js/site-gate.js"></script>
  <script type="module" src="/js/settings-menu.js"></script>
</body>
</html>
