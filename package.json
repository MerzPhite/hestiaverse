{
  "name": "hestiaverse",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "eleventy && tsc && esbuild src/auth.ts src/site-gate.ts src/home-panels.ts src/assessment-funnel.ts src/subscribe-checkout.ts src/settings-menu.ts src/landing-signup.ts --bundle --splitting --format=esm --outdir=dist/js --platform=browser",
    "deploy": "npm run build && wrangler deploy",
    "dev": "eleventy --serve",
    "dev:full": "npm run build && concurrently \"eleventy --serve --watch\" \"tsc --watch\"",
    "create-article": "node scripts/create-article.js",
    "accept-article": "node scripts/accept-article.js",
    "queue-dashboard": "node scripts/queue-dashboard.js",
    "fetch-trends": "node scripts/fetch-trends.js",
    "fetch-tiktok-trends": "node scripts/fetch-tiktok-trends.js",
    "fetch-connection-topics": "node scripts/fetch-connection-topics.js",
    "fetch-connection-pop-girls": "node scripts/fetch-connection-pop-girls.js"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@cloudflare/workers-types": "^4.20260317.1",
    "concurrently": "^8.2.2",
    "esbuild": "^0.24.2",
    "typescript": "^5.3.0",
    "wrangler": "^4.78.0"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.1",
    "cookie": "^1.1.1",
    "dotenv": "^16.4.7",
    "google-trends-api": "^4.9.2",
    "stripe": "^21.0.1"
  }
}
