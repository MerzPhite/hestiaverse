{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "outDir": "dist/js",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "src/auth.ts",
    "src/site-gate.ts",
    "src/supabase-env.ts",
    "src/checkout-start.ts",
    "src/assessment-funnel.ts",
    "src/subscribe-checkout.ts",
    "src/home-panels.ts"
  ]
}
