# Copy to .env. Never commit .env.

# Supabase (Project Settings → API): used at build time for /login/ client config.
# No quotes. Use the publishable (anon) key for SUPABASE_ANON_KEY, or set SUPABASE_PUBLISHABLE_KEY instead.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Public site origin (no trailing slash). Same as Worker SITE_URL. Used for Supabase email confirmation redirects.
# SITE_URL=https://hestiaverse.leolaker23.workers.dev
# SUPABASE_PUBLISHABLE_KEY=

# Stripe (Products → Prices): embedded at build time for checkout buttons; secrets go to Worker.
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# Worker only (wrangler secret put …): STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET,
# SUPABASE_SERVICE_ROLE_KEY, SITE_URL, plus same price IDs and SUPABASE_URL/ANON if not in wrangler.toml
#
# If the live HTML was built without the vars above, the Worker still serves them from GET /api/public-config
# as long as SUPABASE_URL and SUPABASE_ANON_KEY are set as Worker secrets or [vars].
#
# Edge paywall (worker/paywall.ts): sessions are stored in cookies (@supabase/ssr). After deploy, sign out and
# sign in once if premium pages redirect in a loop. Use `wrangler dev` after `npm run build` to test paywall locally.
